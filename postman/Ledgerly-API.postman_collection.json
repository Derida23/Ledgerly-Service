                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/categories?type=INCOME",
              "host": ["{{baseUrl}}"],
              "path": ["api", "categories"],
              "query": [{ "key": "type", "value": "INCOME" }]
            }
          }
        }
      ]
    },
