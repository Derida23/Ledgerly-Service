{
  "info": {
    "name": "Ledgerly API",
    "description": "Personal expense tracker API.\n\n## How to Login\n1. Run '1. Get Google OAuth URL' request\n2. Copy the 'url' from response body\n3. Open that URL in your browser\n4. Login with your whitelisted Google account\n5. After redirect, open browser DevTools > Application > Cookies\n6. Copy 'better-auth.session_token' value\n7. In Postman: Cookies button > Add domain > paste cookie\n8. Run '2. Check Session' to verify\n9. All other requests are now authenticated!",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://ledgerly-service.vercel.app",
      "type": "string"
    },
    {
      "key": "walletId",
      "value": "",
      "type": "string"
    },
    {
      "key": "walletId2",
      "value": "",
      "type": "string"
    },
    {
      "key": "categoryId",
      "value": "",
      "type": "string"
    },
    {
      "key": "incomeCategoryId",
      "value": "",
      "type": "string"
    },
    {
      "key": "transactionId",
      "value": "",
      "type": "string"
    },
    {
      "key": "recurringId",
      "value": "",
      "type": "string"
    },
    {
      "key": "budgetId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "0. Auth",
      "description": "Login flow: Get OAuth URL → Open in browser → Copy cookie → Verify session",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/"
          }
        },
        {
          "name": "1. Get Google OAuth URL",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.url) {",
                  "  console.log('\\n========================================');",
                  "  console.log('OPEN THIS URL IN YOUR BROWSER:');",
                  "  console.log(res.url);",
                  "  console.log('========================================\\n');",
                  "  console.log('After login, copy cookie from browser DevTools > Application > Cookies > better-auth.session_token');",
                  "  console.log('Then set it in Postman: Cookies button (under Send) > Add domain > paste cookie value');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/sign-in/social",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"provider\": \"google\",\n  \"callbackURL\": \"{{baseUrl}}/\"\n}"
            },
            "description": "Returns a Google OAuth URL. Open it in your browser to login.\n\nAfter Google redirects back, copy the session cookie from browser DevTools and set it in Postman."
          }
        },
        {
          "name": "2. Check Session",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res && res.user) {",
                  "  console.log('Logged in as: ' + res.user.name + ' (' + res.user.email + ')');",
                  "  console.log('Role: ' + (res.user.role || 'N/A'));",
                  "  pm.test('Session is valid', () => pm.expect(res.user.id).to.be.a('string'));",
                  "} else {",
                  "  console.log('Not logged in. Set the session cookie first.');",
                  "  pm.test('Session exists', () => pm.expect.fail('No session'));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/auth/get-session",
            "description": "Verify your session is valid. Should return user data after setting cookie."
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/sign-out",
            "description": "Sign out and clear session cookie."
          }
        }
      ]
    },
    {
      "name": "1. Setup (run once)",
      "description": "Seed default data. Run these first after login.",
      "item": [
        {
          "name": "Seed Default Wallets (7)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/wallets/seed"
          }
        },
        {
          "name": "Seed Default Categories (14)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/categories/seed"
          }
        },
        {
          "name": "Load Wallets → save IDs",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.length > 0) {",
                  "  pm.collectionVariables.set('walletId', res[0].id);",
                  "  console.log('walletId set to: ' + res[0].id + ' (' + res[0].name + ')');",
                  "  if (res.length > 1) {",
                  "    pm.collectionVariables.set('walletId2', res[1].id);",
                  "    console.log('walletId2 set to: ' + res[1].id + ' (' + res[1].name + ')');",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/wallets"
          }
        },
        {
          "name": "Load Expense Categories → save ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.length > 0) {",
                  "  pm.collectionVariables.set('categoryId', res[0].id);",
                  "  console.log('categoryId (expense) set to: ' + res[0].id + ' (' + res[0].name + ')');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/categories?type=EXPENSE",
              "host": ["{{baseUrl}}"],
              "path": ["api", "categories"],
              "query": [{ "key": "type", "value": "EXPENSE" }]
            }
          }
        },
        {
          "name": "Load Income Categories → save ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
